            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"diagnostico-admin-demo\",\n  \"title\": \"Diagnostico Admin Demo\",\n  \"description\": \"Formulario criado via API admin\",\n  \"status\": \"published\",\n  \"steps\": [\n    {\n      \"id\": \"step_1\",\n      \"title\": \"Contexto\",\n      \"description\": \"Dados iniciais\",\n      \"order\": 0\n    },\n    {\n      \"id\": \"step_2\",\n      \"title\": \"Objetivo\",\n      \"description\": \"Meta principal\",\n      \"order\": 1\n    }\n  ],\n  \"questions\": [\n    {\n      \"id\": \"question_nome_demo\",\n      \"stepId\": \"step_1\",\n      \"slug\": \"nome\",\n      \"label\": \"Qual e o seu nome?\",\n      \"type\": \"text\",\n      \"required\": true,\n      \"order\": 0,\n      \"options\": [],\n      \"validation\": {\n        \"minLength\": 2,\n        \"maxLength\": 80\n      }\n    },\n    {\n      \"id\": \"question_email_demo\",\n      \"stepId\": \"step_1\",\n      \"slug\": \"email\",\n      \"label\": \"Qual e o seu email?\",\n      \"type\": \"email\",\n      \"required\": true,\n      \"order\": 1,\n      \"options\": [],\n      \"validation\": {}\n    },\n    {\n      \"id\": \"question_idade_demo\",\n      \"stepId\": \"step_1\",\n      \"slug\": \"idade\",\n      \"label\": \"Qual e a sua idade?\",\n      \"type\": \"number\",\n      \"required\": true,\n      \"order\": 2,\n      \"options\": [],\n      \"validation\": {\n        \"min\": 18,\n        \"max\": 120\n      }\n    },\n    {\n      \"id\": \"question_objetivo_demo\",\n      \"stepId\": \"step_2\",\n      \"slug\": \"objetivo_principal\",\n      \"label\": \"Qual e o seu objetivo principal?\",\n      \"type\": \"single_select\",\n      \"required\": true,\n      \"order\": 3,\n      \"options\": [\n        {\n          \"id\": \"option_1\",\n          \"label\": \"Organizar rotina\",\n          \"value\": \"organizar_rotina\",\n          \"order\": 0\n        },\n        {\n          \"id\": \"option_2\",\n          \"label\": \"Aumentar renda\",\n          \"value\": \"aumentar_renda\",\n          \"order\": 1\n        }\n      ],\n      \"validation\": {}\n    }\n  ],\n  \"settings\": {\n    \"successTitle\": \"Diagnostico enviado\",\n    \"successMessage\": \"Recebemos suas respostas e vamos processar.\",\n    \"errorMessage\": \"Nao foi possivel enviar agora. Tente novamente.\",\n    \"allowRetry\": true\n  }\n}"
            },
